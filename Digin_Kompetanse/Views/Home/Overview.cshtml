@model IEnumerable<Digin_Kompetanse.Models.Kompetanse>

@{
    ViewData["Title"] = "Oversikt over kompetanse";
}

<h2>Oversikt over kompetanse</h2>

<table>
    <thead>
    <tr>
        <th>Bedrift</th>
        <th>E-post</th>
        <th>Fagområde</th>
        <th>Kompetansekategori</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var k in Model)
    {
        <tr>
            <td>@(k.Fagområdes.FirstOrDefault()?.Bedrift?.BedriftNavn ?? "Ukjent")</td>
            <td>@(k.Fagområdes.FirstOrDefault()?.Bedrift?.BedriftEpost ?? "Ukjent")</td>
            <td>
                @if (k.Fagområdes.Any())
                {
                    @string.Join(", ", k.Fagområdes.Select(f => f.FagområdeNavn ?? "Ukjent"))
                }
                else
                {
                    <text>Ukjent</text>
                }
            </td>
            <td>@(k.KompetanseKategori ?? "Ukjent")</td>
        </tr>
    }
    </tbody>
</table>